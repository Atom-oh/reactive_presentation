        <mxCell id="dns-flow-title" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:11px;font-family:Amazon Ember,Arial;&quot;&gt;&lt;b&gt;DNS Resolution Flow:&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="830" width="180" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="dns-flow-desc" value="&lt;font color=&quot;#AABBCC&quot; style=&quot;font-size:10px;font-family:Amazon Ember,Arial;&quot;&gt;Shared DNS Resolver (&lt;font color=&quot;#BB86FC&quot;&gt;BIND Views&lt;/font&gt;) → Source IP 기반 환경별 R53 Inbound Resolver로 conditional forwarding → &lt;font color=&quot;#FF9900&quot;&gt;DX/TGW&lt;/font&gt; → &lt;font color=&quot;#945DF2&quot;&gt;PHZ&lt;/font&gt; → VPCE ENI IP&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="850" width="650" height="20" as="geometry"/>
        </mxCell>

        <!-- Key insight box -->
        <mxCell id="insight-box" value="&lt;font color=&quot;#FFFFFF&quot; style=&quot;font-size:10px;font-family:Amazon Ember,Arial;&quot;&gt;&lt;b&gt;핵심 포인트:&lt;/b&gt; 단일 DNS Resolver가 클라이언트 Source IP 대역을 기반으로 환경별 R53 Inbound Resolver EP로 쿼리를 분기&lt;br&gt;→ BIND &lt;font color=&quot;#BB86FC&quot;&gt;match-clients&lt;/font&gt; 설정으로 10.100.1.0/24(Dev), 10.100.2.0/24(Stg), 10.100.3.0/24(Prod) 트래픽을 각 VPC로 격리&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#37475A;strokeColor=#FF9900;arcSize=12;strokeWidth=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="795" width="850" height="45" as="geometry"/>
